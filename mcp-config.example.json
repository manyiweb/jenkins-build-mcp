{
  "mcpServers": {
    "jenkinsBuild": {
      "command": "uvx",
      "args": [
        "--from", "git+ssh://git@github.com/manyiweb/jenkins-build-mcp.git",
        "jenkins-build-mcp"
      ],
      "env": {
        "JENKINS_BASE_URL": "http://your-jenkins-server:8080/jenkins",
        "JENKINS_USER": "your-username",
        "JENKINS_API_TOKEN": "your-api-token-here"
      },
      "type": "stdio"
    }
  }
}
